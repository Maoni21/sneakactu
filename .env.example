# ──────────────────────────────────────────────────
# SANITY
# ──────────────────────────────────────────────────
# Trouve ces valeurs sur https://sanity.io/manage → ton projet → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Token d'écriture (pour les webhooks n8n et les mutations)
# Ne jamais exposer côté client (pas de NEXT_PUBLIC_)
SANITY_API_TOKEN=your_sanity_api_token

# ──────────────────────────────────────────────────
# ANALYTICS (à brancher après le 1er déploiement)
# ──────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────────
# SITE
# ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sneakactu.fr
